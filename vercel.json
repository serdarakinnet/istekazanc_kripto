{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_expo/|assets/|favicon\\.png|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
